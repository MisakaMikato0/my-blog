---
import { announcementConfig } from "@/config";

const items = [...announcementConfig.items].sort((a, b) => b.sort - a.sort);
---

{
	items.length > 0 && (
		<home-ticker
			class="home-ticker"
			aria-label="公告跑马灯"
			data-speed="100"
			data-ready="false"
		>
			<div class="home-ticker__inner">
				<div class="home-ticker__track">
					<div class="home-ticker__group">
						<div class="home-ticker__sequence" data-ticker-source>
							{items.map((item) => (
								<span class="home-ticker__item">
									<span class="home-ticker__text">[{item.tag}] {item.content}</span>
									<span class="home-ticker__sep" aria-hidden="true">×</span>
								</span>
							))}
						</div>
					</div>
				</div>
			</div>
		</home-ticker>
	)
}

<script>
	class HomeTicker extends HTMLElement {
		private track: HTMLElement | null = null;
		private inner: HTMLElement | null = null;
		private sourceSequence: HTMLElement | null = null;
		private resizeObserver: ResizeObserver | null = null;
		private layoutFrame = 0;

		connectedCallback() {
			this.track = this.querySelector<HTMLElement>(".home-ticker__track");
			this.inner = this.querySelector<HTMLElement>(".home-ticker__inner");

			if (!this.track || !this.inner) return;

			if (!this.sourceSequence) {
				const source = this.querySelector<HTMLElement>("[data-ticker-source]");
				if (!source) return;
				this.sourceSequence = source.cloneNode(true) as HTMLElement;
				this.sourceSequence.removeAttribute("data-ticker-source");
			}

			this.resizeObserver?.disconnect();
			this.resizeObserver = new ResizeObserver(() => this.scheduleLayout());
			this.resizeObserver.observe(this.inner);
			this.scheduleLayout();

			document.fonts?.ready.then(() => {
				if (this.isConnected) this.scheduleLayout();
			});
		}

		disconnectedCallback() {
			this.resizeObserver?.disconnect();
			this.resizeObserver = null;
			cancelAnimationFrame(this.layoutFrame);
		}

		private scheduleLayout() {
			cancelAnimationFrame(this.layoutFrame);
			this.layoutFrame = requestAnimationFrame(() => this.layout());
		}

		private layout() {
			if (!this.track || !this.inner || !this.sourceSequence) return;

			this.dataset.ready = "false";

			const group = document.createElement("div");
			group.className = "home-ticker__group";

			const firstSequence = this.sourceSequence.cloneNode(true) as HTMLElement;
			group.appendChild(firstSequence);
			this.track.replaceChildren(group);

			const sequenceWidth = firstSequence.getBoundingClientRect().width;
			if (sequenceWidth <= 0) return;

			const copiesPerGroup = Math.max(
				1,
				Math.ceil((this.inner.clientWidth + 1) / sequenceWidth),
			);

			for (let index = 1; index < copiesPerGroup; index += 1) {
				const repeatedSequence = this.sourceSequence.cloneNode(true) as HTMLElement;
				repeatedSequence.setAttribute("aria-hidden", "true");
				group.appendChild(repeatedSequence);
			}

			const duplicateGroup = group.cloneNode(true) as HTMLElement;
			duplicateGroup.setAttribute("aria-hidden", "true");
			this.track.appendChild(duplicateGroup);

			const distance = group.getBoundingClientRect().width;
			const configuredSpeed = Number.parseFloat(this.dataset.speed ?? "");
			const speed = configuredSpeed > 0 ? configuredSpeed : 100;
			this.style.setProperty("--home-ticker-duration", `${distance / speed}s`);
			this.dataset.ready = "true";
		}
	}

	if (!customElements.get("home-ticker")) {
		customElements.define("home-ticker", HomeTicker);
	}
</script>
