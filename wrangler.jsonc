{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "my-blog",
	"compatibility_date": "2026-05-07",
	"compatibility_flags": ["nodejs_compat"],
	"vars": {
		"NODE_VERSION": "22"
	},
	"vectorize": [
		{
			"binding": "VECTORIZE",
			"index_name": "blog-ai-search"
		}
	],
	"ai": {
		"binding": "AI"
	}
}
