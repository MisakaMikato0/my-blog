---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { getIconSvg } from "@/constants/icons";
import { isHomePage } from "@/utils/layout-utils";
import { url } from "@/utils/url-utils";

interface Props {
	title?: string;
	postSlug?: string;
	postCategory?: string;
}

const { title, postSlug, postCategory } = Astro.props as Props;

const pathname = Astro.url.pathname.replace(/\/$/, "");
const searchParams = Astro.url.searchParams;

const homeUrl = url("/");
const archiveUrl = url("/archive/");
const isHome = isHomePage(pathname);

interface BreadcrumbItem {
	label: string;
	href: string;
	icon: string;
	isCurrent: boolean;
}

let items: BreadcrumbItem[] = [];

if (isHome) {
	items = [];
} else if (postSlug) {
	const category = postCategory || "";
	const categoryHref = category
		? `${archiveUrl}?category=${encodeURIComponent(category)}`
		: archiveUrl;
	items = [
		{
			label: i18n(I18nKey.home),
			href: homeUrl,
			icon: "material-symbols:home-rounded",
			isCurrent: false,
		},
		...(category
			? [
					{
						label: category,
						href: categoryHref,
						icon: "material-symbols:folder-open-rounded",
						isCurrent: false,
					},
				]
			: []),
		{
			label: title || "",
			href: "",
			icon: "material-symbols:article-rounded",
			isCurrent: true,
		},
	];
} else if (pathname === archiveUrl.replace(/\/$/, "")) {
	const categoryParam = searchParams.get("category") || "";
	if (categoryParam) {
		items = [
			{
				label: i18n(I18nKey.home),
				href: homeUrl,
				icon: "material-symbols:home-rounded",
				isCurrent: false,
			},
			{
				label: categoryParam,
				href: `${archiveUrl}?category=${encodeURIComponent(categoryParam)}`,
				icon: "material-symbols:folder-open-rounded",
				isCurrent: true,
			},
		];
	} else {
		items = [
			{
				label: i18n(I18nKey.home),
				href: homeUrl,
				icon: "material-symbols:home-rounded",
				isCurrent: false,
			},
			{
				label: i18n(I18nKey.archive),
				href: archiveUrl,
				icon: "material-symbols:folder-rounded",
				isCurrent: true,
			},
		];
	}
} else if (pathname === "/about") {
	items = [
		{
			label: i18n(I18nKey.home),
			href: homeUrl,
			icon: "material-symbols:home-rounded",
			isCurrent: false,
		},
		{
			label: i18n(I18nKey.about),
			href: "/about/",
			icon: "material-symbols:info-outline-rounded",
			isCurrent: true,
		},
	];
} else if (pathname === "/friends") {
	items = [
		{
			label: i18n(I18nKey.home),
			href: homeUrl,
			icon: "material-symbols:home-rounded",
			isCurrent: false,
		},
		{
			label: i18n(I18nKey.friends),
			href: "/friends/",
			icon: "material-symbols:group-rounded",
			isCurrent: true,
		},
	];
} else if (pathname === "/guestbook") {
	items = [
		{
			label: i18n(I18nKey.home),
			href: homeUrl,
			icon: "material-symbols:home-rounded",
			isCurrent: false,
		},
		{
			label: i18n(I18nKey.guestbook),
			href: "/guestbook/",
			icon: "material-symbols:mode-comment-rounded",
			isCurrent: true,
		},
	];
} else if (pathname === "/gallery" || pathname.startsWith("/gallery/")) {
	const albumMatch = pathname.match(/^\/gallery\/(.+)$/);
	if (albumMatch) {
		items = [
			{
				label: i18n(I18nKey.home),
				href: homeUrl,
				icon: "material-symbols:home-rounded",
				isCurrent: false,
			},
			{
				label: i18n(I18nKey.gallery),
				href: "/gallery/",
				icon: "material-symbols:photo-library-outline-rounded",
				isCurrent: false,
			},
			{
				label: title || decodeURIComponent(albumMatch[1]),
				href: "",
				icon: "material-symbols:photo-frame-rounded",
				isCurrent: true,
			},
		];
	} else {
		items = [
			{
				label: i18n(I18nKey.home),
				href: homeUrl,
				icon: "material-symbols:home-rounded",
				isCurrent: false,
			},
			{
				label: i18n(I18nKey.gallery),
				href: "/gallery/",
				icon: "material-symbols:photo-library-outline-rounded",
				isCurrent: true,
			},
		];
	}
} else if (pathname === "/sponsor") {
	items = [
		{
			label: i18n(I18nKey.home),
			href: homeUrl,
			icon: "material-symbols:home-rounded",
			isCurrent: false,
		},
		{
			label: title || i18n(I18nKey.sponsor),
			href: "/sponsor/",
			icon: "material-symbols:volunteer-activism-rounded",
			isCurrent: true,
		},
	];
} else if (pathname === "/search") {
	items = [
		{
			label: i18n(I18nKey.home),
			href: homeUrl,
			icon: "material-symbols:home-rounded",
			isCurrent: false,
		},
		{
			label: title || i18n(I18nKey.search),
			href: "/search/",
			icon: "material-symbols:search-rounded",
			isCurrent: true,
		},
	];
} else if (pathname === "/bangumi") {
	items = [
		{
			label: i18n(I18nKey.home),
			href: homeUrl,
			icon: "material-symbols:home-rounded",
			isCurrent: false,
		},
		{
			label: title || i18n(I18nKey.bangumi),
			href: "/bangumi/",
			icon: "material-symbols:tv-outline-rounded",
			isCurrent: true,
		},
	];
} else if (items.length === 0 && !isHome) {
	items = [
		{
			label: i18n(I18nKey.home),
			href: homeUrl,
			icon: "material-symbols:home-rounded",
			isCurrent: false,
		},
		{
			label: title || "",
			href: "",
			icon: "material-symbols:description-rounded",
			isCurrent: true,
		},
	];
}

function escapeHtml(str: string): string {
	return str
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;")
		.replace(/"/g, "&quot;");
}

let breadcrumbHtml = "";
if (items.length > 0) {
	const liHtml = items
		.map((item, idx) => {
			const separator =
				idx > 0
					? `<span class="breadcrumb-separator text-(--content-meta) mx-1 select-none" aria-hidden="true">›</span>`
					: "";
			const iconSvg = `<span class="inline-flex shrink-0">${getIconSvg(item.icon)}</span>`;
			if (item.isCurrent) {
				return `${separator}<span class="breadcrumb-current flex items-center gap-1 text-(--deep-text) font-medium">${iconSvg}<span>${escapeHtml(item.label)}</span></span>`;
			}
			return `${separator}<a href="${escapeHtml(item.href)}" class="breadcrumb-link flex items-center gap-1 text-(--content-meta) hover:text-(--primary) transition-colors duration-150 rounded px-1 -mx-1">${iconSvg}<span>${escapeHtml(item.label)}</span></a>`;
		})
		.join("");
	breadcrumbHtml = `<ol class="breadcrumb-list flex items-center flex-wrap gap-1 text-sm"><li class="breadcrumb-item flex items-center gap-1">${liHtml}</li></ol>`;
}
---

{items.length > 0 && (
<nav class="card-base breadcrumb-nav p-3 onload-animation" id="breadcrumb-nav" aria-label="Breadcrumb" set:html={breadcrumbHtml}>
</nav>
)}

<style>
	.breadcrumb-nav {
		margin-bottom: 1rem;
	}
	.breadcrumb-link:hover :global(svg) {
		color: var(--primary);
	}
	.breadcrumb-current :global(svg) {
		color: var(--primary);
		opacity: 0.8;
	}
	.breadcrumb-separator {
		font-size: 0.875rem;
		line-height: 1;
		font-weight: 500;
	}
</style>