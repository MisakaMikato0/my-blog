layout: null
---

<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>博客管理</title>
  <link rel="stylesheet" href="https://unpkg.com/sveltia-cms@2/dist/sveltia-cms.css" />
  <style>
    :root {
      --background: #0b0b0b;
      --foreground: #eee;
      --primary: #7c3aed;
      --primary-light: #a78bfa;
      --text: #d1d5db;
      --text-light: #9ca3af;
      --gray: #1f2937;
      --gray-light: #374151;
      --border: #374151;
      --radius: 8px;
    }
  </style>
</head>
<body>
  <script src="https://unpkg.com/sveltia-cms@2/dist/sveltia-cms.js"></script>
  <script>
    SveltiaCMS.register({
      backend: {
        name: "github",
        repo: "MisakaMikato0/my-blog",
        branch: "master",
        base_url: "https://my-blog-cms-auth.ltznb666.workers.dev",
        auth_endpoint: "auth",
      },
      media_folder: "public/assets",
      public_folder: "/assets",
      collections: [
        {
          name: "posts",
          label: "文章",
          label_singular: "文章",
          folder: "src/content/posts",
          create: true,
          delete: true,
          format: "yaml-frontmatter",
          sortable_fields: ["published", "title"],
          fields: [
            { label: "标题", name: "title", widget: "string" },
            { label: "发布日期", name: "published", widget: "datetime", format: "YYYY-MM-DD" },
            { label: "描述", name: "description", widget: "text", required: false },
            { label: "标签", name: "tags", widget: "list", required: false },
            { label: "分类", name: "category", widget: "string" },
            { label: "草稿", name: "draft", widget: "boolean", default: false, required: false },
            { label: "正文", name: "body", widget: "markdown" },
          ],
        },
      ],
    });
  </script>
</body>
</html>
