---
export interface Props {
	title: string;
	href: string;
	imgurl: string;
	desc: string;
	tags?: string[];
}

const { title, href, imgurl, desc, tags = [] } = Astro.props;
---

<a
  class="friend-card-link"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
>
  <img
    src={imgurl}
    alt={title}
    class="friend-card-avatar"
    loading="lazy"
    onerror="this.style.display='none'"
  />
  <div class="friend-card-info">
    <div class="friend-card-header">
      <h3 class="friend-card-title">{title}</h3>
      <svg
        class="friend-card-arrow"
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M7 17L17 7"></path>
        <path d="M7 7h10v10"></path>
      </svg>
    </div>
    <div class="friend-card-desc-wrapper">
      <p class="friend-card-desc">{desc}</p>
      <span class="friend-card-tooltip">{desc}</span>
    </div>
    {tags.length > 0 && (
      <div class="friend-card-tags">
        {tags.slice(0, 2).map((tag) => (
          <span class="friend-card-tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style is:global>
  .friend-card-link {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    border-radius: var(--radius-large, 0.75rem);
    background: transparent;
    border: 1px solid oklch(0.3 0 0);
    text-decoration: none;
    transition: border-color 200ms, box-shadow 200ms;
    height: 100%;
    position: relative;
  }

  :root:not(.dark) .friend-card-link {
    background: transparent;
    border-color: oklch(0.75 0 0);
  }

  .friend-card-link:hover {
    border-color: oklch(0.5 0 0);
  }

  :root:not(.dark) .friend-card-link:hover {
    border-color: oklch(0.4 0 0);
  }

  .friend-card-avatar {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 0.75rem;
    object-fit: cover;
    flex-shrink: 0;
    background: oklch(0.2 0 0);
  }

  :root:not(.dark) .friend-card-avatar {
    background: oklch(0.85 0 0);
  }

  .friend-card-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .friend-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .friend-card-title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(0.95 0 0);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :root:not(.dark) .friend-card-title {
    color: oklch(0.15 0 0);
  }

  .friend-card-arrow {
    color: oklch(0.6 0 0);
    opacity: 0;
    transform: translate(-2px, 2px);
    transition: opacity 200ms, transform 200ms;
    flex-shrink: 0;
  }

  .friend-card-link:hover .friend-card-arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  .friend-card-desc-wrapper {
    position: relative;
    display: block;
  }

  .friend-card-desc {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 400;
    color: oklch(0.55 0 0);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    cursor: help;
  }

  :root:not(.dark) .friend-card-desc {
    color: oklch(0.45 0 0);
  }

  .friend-card-tooltip {
    position: absolute;
    left: 0;
    top: calc(100% + 6px);
    z-index: 100;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    background: oklch(0.2 0 0);
    border: 1px solid oklch(0.35 0 0);
    color: oklch(0.9 0 0);
    font-size: 0.75rem;
    line-height: 1.4;
    white-space: normal;
    max-width: 280px;
    word-wrap: break-word;
    opacity: 0;
    visibility: hidden;
    transition: opacity 200ms, visibility 200ms;
    pointer-events: none;
    box-shadow: 0 4px 12px oklch(0 0 0 / 0.2);
  }

  :root:not(.dark) .friend-card-tooltip {
    background: oklch(0.98 0 0);
    border-color: oklch(0.8 0 0);
    color: oklch(0.2 0 0);
    box-shadow: 0 4px 12px oklch(0 0 0 / 0.1);
  }

  .friend-card-desc-wrapper:hover .friend-card-tooltip {
    opacity: 1;
    visibility: visible;
  }

  .friend-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.125rem;
  }

  .friend-card-tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background: transparent;
    border: 1px solid oklch(0.35 0 0);
    color: oklch(0.6 0 0);
    line-height: 1.5;
    white-space: nowrap;
  }

  :root:not(.dark) .friend-card-tag {
    background: transparent;
    border-color: oklch(0.8 0 0);
    color: oklch(0.45 0 0);
  }
</style>
