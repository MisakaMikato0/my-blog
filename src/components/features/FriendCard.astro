---
export interface Props {
	title: string;
	href: string;
	imgurl: string;
	desc: string;
	tags?: string[];
}

const { title, href, imgurl, desc, tags = [] } = Astro.props;

// 类型标签：标明是文档还是博客
const tagLabels: Record<string, string> = {
	Blog: "博客",
	Docs: "文档",
};

const primaryTag = tags[0] || "Blog";
const tagLabel = tagLabels[primaryTag] || primaryTag;

// 头像加载失败 / 骨架占位使用的首字
const initial = title.trim().slice(0, 1);
---

<a
  class="friend-card-link"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  title={desc}
>
  <!-- 涂鸦装饰：星星（黄色） -->
  <svg class="friend-card-doodle friend-card-doodle--star" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <path d="M12 2L15 9L22 10L17 15L18.5 22L12 18.5L5.5 22L7 15L2 10L9 9L12 2Z"></path>
  </svg>
  <!-- 涂鸦装饰：闪光（薄荷绿） -->
  <svg class="friend-card-doodle friend-card-doodle--sparkle" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <path d="M12 0C12 6.6 17.4 12 24 12C17.4 12 12 17.4 12 24C12 17.4 6.6 12 0 12C6.6 12 12 6.6 12 0Z"></path>
  </svg>
  <!-- 涂鸦装饰：旋涡（薰衣草色） -->
  <svg class="friend-card-doodle friend-card-doodle--swirl" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <path d="M50 10C27.9 10 10 27.9 10 50C10 72.1 27.9 90 50 90C72.1 90 90 72.1 90 50C90 32.3 75.7 18 58 18C44.3 18 33 29.3 33 43C33 53.5 41.5 62 52 62C59.7 62 66 55.7 66 48"></path>
  </svg>

  <!-- 顶部标签：标明是文档还是博客 -->
  <span class="friend-card-tab">{tagLabel}</span>

  <!-- 第一层：头像（未加载/失败时显示手绘涂鸦头像，加载成功后淡入替换） -->
  <!-- 真实地址存于 data-src，由 friends.astro 的分页逻辑在卡片可见时注入 src，
       避免 loading=lazy + display:none 在 Swup 导航后不触发加载的问题 -->
  <div class="friend-card-avatar" data-initial={initial}>
    <span class="friend-card-avatar__face" aria-hidden="true"></span>
    <img
      alt={title}
      class="friend-card-avatar__img"
      data-src={imgurl}
    />
  </div>

  <!-- 第二层：名字 -->
  <h3 class="friend-card-name">{title}</h3>

  <!-- 第三层：介绍框（默认一行，悬停向下扩展显示更多，超出截断） -->
  <div class="friend-card-intro">
    <p class="friend-card-intro__text">{desc}</p>
  </div>
</a>

<!-- 样式已迁移至 src/styles/components/friend-card.css -->
